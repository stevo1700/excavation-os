# Copy this file to .env.local (for Next.js) and .env (for Prisma CLI), then
# fill in real values. Never commit your filled-in secrets.

# ----------------------------------------------------------------------------
# Database (Postgres) — used by Prisma
# ----------------------------------------------------------------------------
# Local example: postgresql://postgres:postgres@localhost:5432/excavation_os
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/excavation_os?schema=public"

# ----------------------------------------------------------------------------
# Clerk authentication — https://dashboard.clerk.com
# ----------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_your_publishable_key_here"
CLERK_SECRET_KEY="sk_test_your_secret_key_here"

# ----------------------------------------------------------------------------
# App URL — used to build the canonical /e/<assetTag> QR scan URL.
# Falls back to a relative path (/e/<assetTag>) if unset.
# ----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="https://your-deployment.example.com"

# ----------------------------------------------------------------------------
# Telematics integrations — /dashboard/integrations (optional)
# ----------------------------------------------------------------------------
# Encrypts OEM credentials at rest (AES-256-GCM). Required to connect any OEM.
ENCRYPTION_KEY="a long random secret"

# Each OEM's AEMP 2.0 base URL is dealer/account-specific — there is no global
# default. Only set the ones for OEMs you actually connect.
KOMATSU_AEMP_BASE_URL="https://your-komtrax-aemp-endpoint.example.com"
CASE_AEMP_BASE_URL="https://your-sitewatch-aemp-endpoint.example.com"
BOBCAT_AEMP_BASE_URL="https://your-machine-iq-aemp-endpoint.example.com"
