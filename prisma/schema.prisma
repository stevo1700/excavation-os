// Excavation OS — database schema.
//
// Phase 3 introduces a real Postgres data layer behind the dashboard. The
// shapes here intentionally mirror the domain the UI already renders (jobs,
// equipment, crew, reports, notes, activity) so the seed in prisma/seed.ts can
// load the existing mock data into a real database.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  FOREMAN
  OPERATOR
  LABOURER
}

enum JobStatus {
  QUOTED
  ACTIVE
  ON_HOLD
  COMPLETE
  CANCELLED
}

enum EquipmentStatus {
  IDLE
  IN_USE
  MAINTENANCE
}

enum CrewStatus {
  ON_SITE
  AVAILABLE
  OFF
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  name      String
  email     String   @unique
  role      UserRole @default(LABOURER)
  createdAt DateTime @default(now())

  // Relations
  foremanJobs  Job[]         @relation("JobForeman")
  crewMember   CrewMember?
  dailyReports DailyReport[] @relation("ReportAuthor")
  notes        Note[]        @relation("NoteAuthor")
}

model Job {
  id            String    @id @default(cuid())
  name          String
  client        String
  siteAddress   String
  status        JobStatus @default(QUOTED)
  startDate     DateTime?
  estCompletion DateTime?
  value         Int       @default(0)
  description   String?
  color         String    @default("amber")
  foremanId     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  foreman          User?               @relation("JobForeman", fields: [foremanId], references: [id])
  equipment        Equipment[]
  crew             CrewMember[]
  dailyReports     DailyReport[]
  notes            Note[]
  activity         ActivityEvent[]
  timesheetEntries TimesheetEntry[]
  portalTokens     ClientPortalToken[]
}

model Equipment {
  id             String          @id @default(cuid())
  name           String
  category       String
  make           String?
  model          String?
  year           Int?
  status         EquipmentStatus @default(IDLE)
  hoursThisMonth Int             @default(0)
  jobId          String?
  createdAt      DateTime        @default(now())

  // Relations
  job Job? @relation(fields: [jobId], references: [id])
}

model CrewMember {
  id        String     @id @default(cuid())
  userId    String?    @unique
  name      String
  role      String
  phone     String?
  status    CrewStatus @default(AVAILABLE)
  jobId     String?
  createdAt DateTime   @default(now())

  // Relations
  user             User?            @relation(fields: [userId], references: [id])
  job              Job?             @relation(fields: [jobId], references: [id])
  timesheetEntries TimesheetEntry[]
}

model DailyReport {
  id            String   @id @default(cuid())
  jobId         String
  submittedById String
  date          DateTime
  weather       String?
  summary       String
  hoursWorked   Int      @default(0)
  createdAt     DateTime @default(now())

  // Relations
  job         Job  @relation(fields: [jobId], references: [id])
  submittedBy User @relation("ReportAuthor", fields: [submittedById], references: [id])
}

model Note {
  id        String   @id @default(cuid())
  jobId     String
  authorId  String
  body      String
  createdAt DateTime @default(now())

  // Relations
  job    Job  @relation(fields: [jobId], references: [id])
  author User @relation("NoteAuthor", fields: [authorId], references: [id])
}

model ActivityEvent {
  id          String   @id @default(cuid())
  type        String
  description String
  jobId       String?
  createdAt   DateTime @default(now())

  // Relations
  job Job? @relation(fields: [jobId], references: [id])
}

// ---------------------------------------------------------------------------
// Phase 4 — Operations layer
//
// These two tables are created directly in Neon via the SQL editor (see
// prisma/sql/2026-phase4-operations.sql) because the sandbox cannot reach
// Postgres on TCP 5432. The models below mirror that SQL exactly; the id
// defaults use gen_random_uuid()::text to match the database-side defaults.
// ---------------------------------------------------------------------------

model TimesheetEntry {
  id           String   @id @default(dbgenerated("gen_random_uuid()::text"))
  crewMemberId String
  jobId        String
  date         DateTime @db.Date
  hoursWorked  Decimal  @db.Decimal(5, 2)
  notes        String?
  createdAt    DateTime @default(now())

  crewMember CrewMember @relation(fields: [crewMemberId], references: [id], onDelete: Cascade)
  job        Job        @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model ClientPortalToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()::text"))
  jobId     String
  token     String    @unique
  createdAt DateTime  @default(now())
  expiresAt DateTime?

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([token])
}
