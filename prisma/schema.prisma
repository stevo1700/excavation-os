// Excavation OS — database schema.
//
// The Phase 3 models below were reconciled (Phase 6) to match the columns that
// actually exist in the live Neon database, discovered via an information_schema
// dump. Enum columns are represented as plain String here because their value
// sets weren't introspectable from this environment; the server actions map
// them to the UI's display values. The Phase 4/5 tables already match.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  name      String
  role      String   @default("LABOURER")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  dailyReports DailyReport[] @relation("ReportAuthor")
  notes        Note[]        @relation("NoteAuthor")
}

model Job {
  id            String    @id @default(cuid())
  name          String
  client        String
  status        String    @default("ACTIVE")
  scheduledDate DateTime? @db.Date
  startDate     DateTime?
  endDate       DateTime?
  address       String?
  city          String?
  state         String?
  contractValue Float     @default(0)
  description   String?
  customerId    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  customer         Customer?           @relation(fields: [customerId], references: [id], onDelete: SetNull)
  equipment        Equipment[]
  crew             CrewMember[]
  dailyReports     DailyReport[]
  notes            Note[]
  activity         ActivityEvent[]
  timesheetEntries TimesheetEntry[]
  portalTokens     ClientPortalToken[]
  quotes           Quote[]
  invoices         Invoice[]
}

model Equipment {
  id           String    @id @default(cuid())
  name         String
  type         String
  status       String    @default("AVAILABLE")
  year         Int?
  make         String?
  model        String?
  serialNumber String?
  jobId        String?
  lastService  DateTime?
  nextService  DateTime?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  job Job? @relation(fields: [jobId], references: [id])
}

model CrewMember {
  id             String    @id @default(cuid())
  name           String
  role           String
  status         String    @default("available")
  phone          String?
  email          String?
  jobId          String?
  certifications String[]
  hireDate       DateTime?
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  job              Job?             @relation(fields: [jobId], references: [id])
  timesheetEntries TimesheetEntry[]
}

model DailyReport {
  id            String   @id @default(cuid())
  jobId         String
  date          DateTime
  status        String?
  weather       String?
  temperature   Int?
  workPerformed String
  hoursWorked   Float    @default(0)
  crewCount     Int?
  safetyNotes   String?
  authorId      String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  job    Job  @relation(fields: [jobId], references: [id])
  author User @relation("ReportAuthor", fields: [authorId], references: [id])
}

model Note {
  id         String   @id @default(cuid())
  jobId      String
  content    String
  authorId   String?
  authorName String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  job    Job   @relation(fields: [jobId], references: [id])
  author User? @relation("NoteAuthor", fields: [authorId], references: [id])
}

model ActivityEvent {
  id          String   @id @default(cuid())
  type        String
  jobId       String?
  description String
  metadata    Json?
  userId      String?
  createdAt   DateTime @default(now())

  // Relations
  job Job? @relation(fields: [jobId], references: [id])
}

// ---------------------------------------------------------------------------
// Phase 4 — Operations layer (matches the live DB)
// ---------------------------------------------------------------------------

model TimesheetEntry {
  id           String   @id @default(dbgenerated("gen_random_uuid()::text"))
  crewMemberId String
  jobId        String
  date         DateTime @db.Date
  hoursWorked  Decimal  @db.Decimal(5, 2)
  notes        String?
  createdAt    DateTime @default(now())

  crewMember CrewMember @relation(fields: [crewMemberId], references: [id], onDelete: Cascade)
  job        Job        @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model ClientPortalToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()::text"))
  jobId     String
  token     String    @unique
  createdAt DateTime  @default(now())
  expiresAt DateTime?

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([token])
}

// ---------------------------------------------------------------------------
// Phase 5 — Financial layer + CRM (matches the live DB)
// ---------------------------------------------------------------------------

model Customer {
  id          String   @id @default(dbgenerated("gen_random_uuid()::text"))
  name        String
  contactName String?
  email       String?
  phone       String?
  address     String?
  notes       String?
  stage       String   @default("Lead")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  jobs     Job[]
  quotes   Quote[]
  invoices Invoice[]
}

model Quote {
  id          String    @id @default(dbgenerated("gen_random_uuid()::text"))
  jobId       String
  customerId  String?
  quoteNumber String    @unique
  status      String    @default("DRAFT")
  lineItems   Json      @default("[]")
  subtotal    Decimal   @default(0) @db.Decimal(12, 2)
  taxRate     Decimal   @default(0) @db.Decimal(5, 4)
  taxAmount   Decimal   @default(0) @db.Decimal(12, 2)
  total       Decimal   @default(0) @db.Decimal(12, 2)
  notes       String?
  validUntil  DateTime? @db.Date
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  job      Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  invoices Invoice[]
}

model Invoice {
  id            String    @id @default(dbgenerated("gen_random_uuid()::text"))
  jobId         String
  customerId    String?
  quoteId       String?
  invoiceNumber String    @unique
  status        String    @default("DRAFT")
  lineItems     Json      @default("[]")
  subtotal      Decimal   @default(0) @db.Decimal(12, 2)
  taxRate       Decimal   @default(0) @db.Decimal(5, 4)
  taxAmount     Decimal   @default(0) @db.Decimal(12, 2)
  total         Decimal   @default(0) @db.Decimal(12, 2)
  amountPaid    Decimal   @default(0) @db.Decimal(12, 2)
  dueDate       DateTime? @db.Date
  paidAt        DateTime?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  job      Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  quote    Quote?    @relation(fields: [quoteId], references: [id], onDelete: SetNull)
}
